rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all by default — only explicitly matched paths are accessible
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles — only owner can write, any authed user can read (for display names)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['displayName', 'email', 'photoURL', 'createdAt']);
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'photoURL']);
    }

    // Conversations
    match /conversations/{convId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;

      // Only members listed in the conversation can create it
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() >= 2
                    && request.resource.data.members.size() <= 50
                    && request.resource.data.keys().hasOnly(['type', 'members', 'name', 'lastMessage', 'lastMessageAt', 'updatedAt']);

      // Only members can update, and only metadata fields
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt', 'name']);

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members;

        // Only conversation members can write, authorId must match, message must have required fields
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.keys().hasOnly(['id', 'authorId', 'authorName', 'convId', 'body', 'createdAt'])
                      && request.resource.data.body is string
                      && request.resource.data.body.size() <= 10000;
      }
    }

    // Contacts — private per user; either owner or the contact themselves can create (for accept flow)
    match /contacts/{ownerId}/list/{contactId} {
      allow read, delete: if request.auth != null && request.auth.uid == ownerId;
      allow create: if request.auth != null
                    && (request.auth.uid == ownerId || request.auth.uid == contactId)
                    && request.resource.data.keys().hasOnly(['userId', 'displayName', 'email', 'addedAt']);
    }

    // Contact requests — sender creates/overwrites, recipient reads/deletes
    match /contactRequests/{recipientId}/inbox/{senderId} {
      allow read, delete: if request.auth != null && request.auth.uid == recipientId;
      allow create, update: if request.auth != null
                            && request.auth.uid == senderId
                            && request.resource.data.fromUserId == request.auth.uid
                            && request.resource.data.keys().hasOnly(['fromUserId', 'fromDisplayName', 'fromEmail', 'createdAt']);
    }

    // Channels
    match /channels/{channelId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.keys().hasOnly(['name', 'description', 'ownerId', 'createdAt', 'subscriberCount', 'lastPost', 'lastPostAt']);

      // Only owner can update channel metadata
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['name', 'description', 'lastPost', 'lastPostAt', 'subscriberCount']);

      // Posts — subscribers can read, only channel owner can create
      match /posts/{postId} {
        allow read: if request.auth != null
                    && exists(/databases/$(database)/documents/channels/$(channelId)/subscribers/$(request.auth.uid));
        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid
                      && get(/databases/$(database)/documents/channels/$(channelId)).data.ownerId == request.auth.uid
                      && request.resource.data.keys().hasOnly(['id', 'authorId', 'authorName', 'body', 'createdAt'])
                      && request.resource.data.body is string
                      && request.resource.data.body.size() <= 10000;
      }

      // Subscribers — anyone can subscribe/unsubscribe themselves
      match /subscribers/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.keys().hasOnly(['joinedAt']);
        allow delete: if request.auth != null
                      && request.auth.uid == userId;
      }
    }

    // P2P signalling — kept for WebRTC
    match /signals/{recipientUid}/inbox/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.from == request.auth.uid;
      allow read, delete: if request.auth != null
                          && request.auth.uid == recipientUid;
    }
  }
}
